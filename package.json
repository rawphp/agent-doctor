{
  "name": "agent-doctor",
  "version": "0.1.0",
  "description": "Diagnose and fix AI-agent project setup (skills hub, adapters, maps, status)",
  "type": "module",
  "bin": {
    "agent-doctor": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "node scripts/prepare.mjs",
    "test": "vitest run",
    "cli": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rawphp/agent-doctor.git"
  },
  "homepage": "https://github.com/rawphp/agent-doctor#readme",
  "bugs": {
    "url": "https://github.com/rawphp/agent-doctor/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "agent",
    "cli",
    "skills",
    "claude",
    "codex",
    "grok"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.20.1",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}
